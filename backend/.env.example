ANTHROPIC_API_KEY=your_anthropic_api_key_here
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx
CONNECTEAM_API_KEY=your_connecteam_api_key
CONNECTEAM_COMPANY_ID=your_connecteam_company_id

# Database — point to Railway persistent volume
DATABASE_URL=sqlite:////data/brightbase.db

# Email (Gmail + App Password)
SMTP_USER=hello@maineclean.co
SMTP_PASS=your_gmail_app_password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
FROM_EMAIL=hello@maineclean.co
FROM_NAME=Maine Cleaning Co

# Google Calendar — base64-encode your local JSON files:
#   PowerShell: [Convert]::ToBase64String([IO.File]::ReadAllBytes("google_token.json"))
#   bash:       base64 -w0 google_token.json
GOOGLE_TOKEN_B64=
GOOGLE_CREDENTIALS_B64=
GCAL_RESIDENTIAL_ID=primary
GCAL_COMMERCIAL_ID=primary
GCAL_STR_ID=primary
